# Git LFS configuration for large files

# PyTorch model files - use LFS for .pt and .pth files
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text

# RL runs checkpoint files - explicitly use LFS
baseline/RL/runs/**/*.pt filter=lfs diff=lfs merge=lfs -text
baseline/RL/runs/**/*.pth filter=lfs diff=lfs merge=lfs -text
