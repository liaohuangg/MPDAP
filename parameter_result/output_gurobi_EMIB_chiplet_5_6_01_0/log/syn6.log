  2. Area term:
     norm_t = t / ref_t
     contribution = beta_area * norm_t = 6.0 * norm_t
  3. Aspect Ratio term:
     norm_aspect = aspect_ratio_penalty / ref_aspect
     contribution = beta_aspect * norm_aspect = 0.1 * norm_aspect
  4. Power Awareness term:
     norm_power = power_aware_penalty / ref_power
     contribution = - beta_power * norm_power = - 0.0 * norm_power

[Objective Function Formula]
  minimize: 5.0 * wirelength/ref_wirelength
          + 6.0 * t/ref_t
          + 0.1 * aspect_ratio_penalty/ref_aspect
          - 0.0 * power_aware_penalty/ref_power
